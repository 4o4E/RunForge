# ---- Server ----
# 开发环境绑定 IPv6 任意地址,适配浏览器/SSH 把 localhost 解析到 ::1 的情况。
# 常见 Linux 双栈 socket 下也会同时接受 IPv4。
HOST=::
PORT=8080

# ---- Access control ----
# 后端 API 和 WebSocket 访问 token。前端会通过 Authorization Header 发送，
# 不会放进 Cookie 或 URL。
RUNFORGE_ACCESS_TOKEN=replace-with-a-strong-local-token
# 文件分享签名密钥；不填时会复用 RUNFORGE_ACCESS_TOKEN，建议生产/公网环境单独配置。
RUNFORGE_SHARE_SECRET=replace-with-a-different-share-secret

# PostgreSQL connection
DATABASE_URL=postgres://postgres:postgres@localhost:5432/my_agent

# ---- LLM provider ----
# LLM 后端:
#   aisdk             默认路径,由 Vercel AI SDK 处理协议、流式、重试和工具拼装
#   openai-responses  手写旧实现,仅作为 OpenAI Responses API 回滚路径
#   openai-chat       手写旧实现,仅作为 OpenAI-compatible Chat Completions 回滚路径
#   anthropic         手写旧实现,仅作为 Anthropic Messages API 回滚路径
#   mock              离线确定性 provider,用于本地演示和测试
LLM_PROVIDER=aisdk

# AI SDK flavor,仅在 LLM_PROVIDER=aisdk 时生效:
#   openai-compatible  DeepSeek / Moonshot / tencentmaas / vLLM / Ollama(默认)
#   openai             OpenAI 原生协议
#   anthropic          Anthropic 原生协议
LLM_AISDK_FLAVOR=openai-compatible
# 将 <tag>...</tag> 推理内容从正文中拆出,适配 DeepSeek 风格;置空表示关闭。
LLM_REASONING_TAG=think

LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-xxxx
LLM_MODEL=gpt-4o-mini
LLM_MAX_TOKENS=4096

# Per-request timeout, and retries on transient failures (timeout / 429 / 5xx).
LLM_TIMEOUT_MS=120000
LLM_MAX_RETRIES=2

# Stream tokens for live rendering (set false to disable).
LLM_STREAM=true

# Optional: web_search / web_fetch tooling
# (web_search uses LLM_* by default; set a real search API if you have one)

# Agent 循环硬兜底:长任务主要由完成、取消或上下文预算结束;这里只防失控循环。
AGENT_HARD_STEP_CAP=1000

# ---- Tool sandbox / permissions defaults ----
# These env values are startup defaults / fallback values. Runtime settings are
# stored in app_settings and can be edited at /settings.
# This is a general-purpose OS agent, so confinement is opt-in by default.
#   off      (default) only deny/allow lists + output cap apply
#   enforce  path confinement, shell gating, network switch
TOOL_SANDBOX=off
# Shell process backend in enforce mode:
#   auto   Linux + usable bwrap -> bwrap, otherwise host execution with warning
#   none   host execution
#   bwrap  require bubblewrap; fail if unavailable
TOOL_SANDBOX_BACKEND=auto
# Filesystem tools are confined under this root in enforce mode (default: repo root).
# TOOL_WORKSPACE_ROOT=/path/to/workspace
# Tool gating (comma separated). DENY always wins; if ALLOW is set, only those run.
# TOOL_DENY=shell
# TOOL_ALLOW=file_read,glob,grep
# Shell: disable entirely, or add blocked command patterns (regex; comma/newline separated).
# SHELL_ENABLED=true
# SHELL_DENY=rm\s+-rf\s+/, Format-Volume
# In bwrap mode, only these external commands are visible inside the sandbox.
# Shell builtins such as cd/echo do not need to be listed.
# SHELL_ALLOW_COMMANDS=cat,ls,pwd,printf,sed,awk,grep,find,head,tail,wc,sort,uniq,xargs,env,git,rg,node,npm
# Network switch for shell/web tools in enforce mode:
#   disabled  block network
#   enabled   allow network without domain/IP restrictions
TOOL_NETWORK=disabled
# 单条工具结果硬上限(字符),始终生效。
TOOL_MAX_OUTPUT=40000

# ---- Observability (Phase 4, OpenTelemetry GenAI) ----
# Off by default (zero overhead). When on, emits invoke_agent → chat →
# execute_tool spans with token usage and tool I/O.
OTEL_ENABLED=false
# OTLP HTTP endpoint of a trace backend (Jaeger/Langfuse/Laminar). With the
# bundled debug profile: docker compose --profile debug up  → http://localhost:4318
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# Also print spans to stdout (handy without a backend):
# OTEL_CONSOLE=true
# OTEL_SERVICE_NAME=my-agent
