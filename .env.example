# ---- Server ----
PORT=8080

# PostgreSQL connection
DATABASE_URL=postgres://postgres:postgres@localhost:5432/my_agent

# ---- LLM provider ----
# Which backend to use:
#   openai-responses  OpenAI Responses API (new protocol, default)
#   openai-chat       OpenAI-compatible Chat Completions (DeepSeek/Moonshot/vLLM/Ollama)
#   anthropic         Anthropic Messages API
#   mock              network-free deterministic provider (offline runs / tests)
LLM_PROVIDER=openai-responses

LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-xxxx
LLM_MODEL=gpt-4o-mini
LLM_MAX_TOKENS=4096

# Per-request timeout, and retries on transient failures (timeout / 429 / 5xx).
LLM_TIMEOUT_MS=120000
LLM_MAX_RETRIES=2

# Stream tokens via SSE for live rendering (set false to disable). openai-chat only.
LLM_STREAM=true

# Optional: web_search / web_fetch tooling
# (web_search uses LLM_* by default; set a real search API if you have one)

# Max agent loop iterations per run (safety cap)
AGENT_MAX_STEPS=25
